{% extends "home/base1.html.twig" %}
{% block title %}Flappy Stage{% endblock %}
{% block body %}
<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport", content="width=devicee-width, initial-scale=1.0">
        <title>Flappy Stage</title>
        <style>
            body{
                font-family: 'Courier New', Courier, monospace;
                text-align: center;
            }

            #board{
                background-image: url("/images/flappybirdbg.png");
            }

        </style>
        <script>
            let board;
            let boardWidth = 360;
            let boardHeight = 640;
            let context;

            let birdWidth = 34;
            let birdHeight = 24;
            let birdX = boardWidth/8;
            let birdY = boardHeight/2;

            let birdImgs = [];
            let birdFrame = 0;
            let frameCounter = 0;

            let bird = {
                x : birdX,
                y : birdY,
                width : birdWidth,
                height : birdHeight
            }

            let pipeArray = [];
            let pipeWidth = 64;
            let pipeHeight = 512;
            let pipeX = boardWidth;
            let pipeY = 0;

            let topPipeImg;
            let bottomPipeImg;

            let velocityX = -2;
            let velocityY = 0;
            let gravity = 0.4;

            let gameOver = false;
            let score = 0;

            let currentLevel = 0;
            let pipeInterval;


            window.onload = function(){
                board = document.getElementById("board");
                board.height = boardHeight;
                board.width = boardWidth;
                context = board.getContext("2d");


                let frames = ["/images/flappybird1.png", "/images/flappybird2.png", "/images/flappybird3.png"];
                frames.forEach((src, i) => {
                    let img = new Image();
                    img.src = src;
                    birdImgs[i] = img;
                });


                topPipeImg = new Image();
                topPipeImg.src = "/images/toppipe.png";

                bottomPipeImg = new Image();
                bottomPipeImg.src = "/images/bottompipe.png";

                requestAnimationFrame(update);
                pipeInterval = setInterval(placePipes, 3000);
                document.addEventListener("keydown", moveBird);
            }

            function update(){
                requestAnimationFrame(update);
                if(gameOver){
                    return;
                }
                context.clearRect(0, 0, board.width, board.height);

                velocityY += gravity;
                bird.y = Math.max(bird.y + velocityY, 0);
                
                frameCounter++;
                if(frameCounter % 8 === 0){
                    birdFrame = (birdFrame + 1) % birdImgs.length;
                }
                context.save();
                context.translate(bird.x + bird.width/2, bird.y + bird.height/2);
                let rotation = Math.min(Math.max(velocityY * 3, -30), 90);
                context.rotate(rotation * Math.PI / 180);
                context.drawImage(birdImgs[birdFrame], -bird.width/2, -bird.height/2, bird.width, bird.height);
                context.restore();

                if(bird.y > board.height){
                    gameOver = true;
                }

                for(let i = 0; i < pipeArray.length; i++){
                    let pipe = pipeArray[i];
                    pipe.x += velocityX;
                    context.drawImage(pipe.img, pipe.x, pipe.y, pipe.width, pipe.height);

                    if(!pipe.passed && bird.x > pipe.x + pipe.width){
                        score += 0.5;
                        pipe.passed = true;
                    }

                    if (detectCollision(bird, pipe)){
                        gameOver = true;
                    }
                }

                while(pipeArray.length > 0 && pipeArray[0].x < -pipeWidth){
                    pipeArray.shift();
                }

                updateSpeed();

                context.fillStyle = "white";
                context.font = "25px sans-serif";
                context.fillText("LVL "+ (currentLevel + 1), 40, 30)
                context.font = "45px sans-serif";
                context.textAlign = "center";
                if(gameOver){
                    context.fillText("GAME OVER", board.width/2, 90);
                    context.textAlign = "left";
                }
            }

            function placePipes(){
                if(gameOver){
                    return;
                }

                let randomPipeY = pipeY - pipeHeight/4 - Math.random()*(pipeHeight/2);
                let openingSpace = board.height/4;

                let topPipe = {
                    img : topPipeImg,
                    x : pipeX,
                    y : randomPipeY,
                    width : pipeWidth,
                    height : pipeHeight,
                    passed : false
                }

                pipeArray.push(topPipe);

                let bottomPipe = {
                    img : bottomPipeImg,
                    x : pipeX,
                    y : randomPipeY + pipeHeight + openingSpace,
                    width : pipeWidth,
                    height : pipeHeight,
                    passed : false
                }

                pipeArray.push(bottomPipe);
            }

            function moveBird(e){
                if(e.code == "Space" || e.code == "ArrowUp" || e.code == "KeyX"){
                    velocityY = -6;

                    if(gameOver){
                        bird.y = birdY;
                        birdFrame = 0;
                        frameCounter = 0;
                        pipeArray = [];
                        score = 0;
                        velocityX = -2;
                        currentLevel = 0;
                        clearInterval(pipeInterval);
                        pipeInterval = setInterval(placePipes, 3000);
                        gameOver = false;
                    }
                }
            }

            function detectCollision(a, b){
                return a.x < b.x + b.width &&
                a.x + a.width > b.x &&
                a.y < b.y + b.height &&
                a.y + a.height > b.y;
            }


            function updateSpeed(){
                let level = Math.floor(score / 5);
                velocityX = -2 - (level * 1);

                if(level !== currentLevel){
                    currentLevel = level;
                    clearInterval(pipeInterval);
                    let newInterval = Math.max(750, 3000 - (level * 750));
                    pipeInterval = setInterval(placePipes, newInterval);
                }
            }
        </script>
    </head>
    <body>
        <canvas id="board"></canvas>
    </body>
</html>
{% endblock %}