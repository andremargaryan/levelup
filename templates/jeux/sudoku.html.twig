{% extends 'home/base1.html.twig' %}

{% block title %}Sudoku
{% endblock %}

{% block body %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Poppins:wght@300;400&display=swap" rel="stylesheet">

    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        
        body {
            font-family: 'Poppins', sans-serif;
            /* Bleu Nuit profond pour le fond */
            background-color: #041021; 
            color: #F5E6D3; /* Crème clair pour le texte */
            text-align: center;
            padding: 40px 20px;
            /* Léger motif texturé discret évoquant le velours */
            background-image: radial-gradient(#081a36 1px, transparent 1px);
            background-size: 20px 20px;
        }
        h1 {
            font-family: 'Playfair Display', serif;
            font-weight: 700;
            font-size: 3rem;
            color: #C6A75E; /* Or Vieilli */
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        }

        .subtitle {
            font-family: 'Playfair Display', serif;
            font-style: italic;
            font-size: 1.2rem;
            color: #A98F4F; /* Or plus sombre */
            margin-bottom: 30px;
        }

        .cpt-container {
            font-size: 1.1rem;
            margin-bottom: 30px;
            color: #F5E6D3;
        }

        #cpt {
            color: #C6A75E; 
            font-weight: bold;
            font-size: 1.3rem;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(9, 50px);
            grid-template-rows: repeat(9, 50px);
            justify-content: center;
            gap: 0; 
            
           
            border: 5px solid #C6A75E; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.8);
            width: fit-content;
            margin: 0 auto;
            background-color: #C6A75E; 
        }

        input {
            width: 50px;
            height: 50px;
            text-align: center;
            font-size: 1.5rem;
            font-family: 'Poppins', sans-serif;
            border: 1px solid rgba(245, 230, 211, 0.2); 
            outline: none;
           
            background-color: #FAF5EF; 
            color: #041021; 
            transition: all 0.3s ease;
        }

        
        input:nth-child(3n) {
            border-right: 3px solid #C6A75E;
        }
        input:nth-child(9n) {
            border-right: 1px solid rgba(245, 230, 211, 0.2); 
        }

        .grid input:nth-child(n+19):nth-child(-n+27),
        .grid input:nth-child(n+46):nth-child(-n+54) {
            border-bottom: 3px solid #C6A75E;
        }

        input:hover:not(:disabled) {
            background-color: #F5E6D3; 
        }

        input:focus:not(:disabled) {
            background-color: #FFF;
            box-shadow: inset 0 0 5px rgba(198, 167, 94, 0.5); 
        }

        input:disabled {
            background-color: #E6DCCF; 
            font-weight: bold;
            color: #333; 
            opacity: 1; 
        }

        .success {
            background-color: #2D5F36 !important; 
            color: #F5E6D3 !important;
            font-weight: bold;
        }

        .error {
            background-color: #8B0000 !important; 
            color: #F5E6D3 !important;
            animation: shake 0.4s ease;
        }

        @keyframes shake {
            0% { transform: translateX(0); }
            25% { transform: translateX(-4px); }
            50% { transform: translateX(4px); }
            75% { transform: translateX(-4px); }
            100% { transform: translateX(0); }
        }

        @media (max-width: 500px) {
            h1 { font-size: 2rem; }
            .grid { grid-template-columns: repeat(9, 35px); grid-template-rows: repeat(9, 35px); }
            input { width: 35px; height: 35px; font-size: 1.1rem; }
        }
    </style>
    <h1>Le Sudoku Royal</h1>
    <p class="subtitle">Une invitation au voyage de l'esprit</p>
    
    <div class="cpt-container">
        Erreurs de parcours : <span id="cpt">0</span>
    </div>

    <div id="sudoku-grid" class="grid">
        </div>

    <script>
        let grille = [
            [5, 3, 0, 0, 7, 0, 0, 0, 0],
            [6, 0, 0, 1, 9, 5, 0, 0, 0],
            [0, 9, 8, 0, 0, 0, 0, 6, 0],
            [8, 0, 0, 0, 6, 0, 0, 0, 3],
            [4, 0, 0, 8, 0, 3, 0, 0, 1],
            [7, 0, 0, 0, 2, 0, 0, 0, 6],
            [0, 6, 0, 0, 0, 0, 2, 8, 0],
            [0, 0, 0, 4, 1, 9, 0, 0, 5],
            [0, 0, 0, 0, 8, 0, 0, 7, 9]
        ];
        let cpt = 0;

        function estValideSurUneLigne(chiffre, ligne) {
            return grille[ligne].includes(chiffre);
        }

        function estValideSurUneColonne(chiffre, col) {
            for(let i = 0; i < 9; i++) { if(grille[i][col] === chiffre) return true; }
            return false;
        }

        function estValideSurUnCarre(chiffre, ligne, col) {
            let lAux = ligne - ligne % 3;
            let cAux = col - col % 3;
            for(let i = lAux; i < lAux + 3; i++) {
                for(let j = cAux; j < cAux + 3; j++) {
                    if(grille[i][j] === chiffre) return true;
                }
            }
            return false;
        }

        function testCoup(ligne, col, chiffre) {
            if (!estValideSurUneLigne(chiffre, ligne) && 
                !estValideSurUneColonne(chiffre, col) && 
                !estValideSurUnCarre(chiffre, ligne, col)) {
                grille[ligne][col] = chiffre;
                return true;
            }
            cpt++;
            document.getElementById('cpt').innerText = cpt;
            return false;
        }

        const container = document.getElementById('sudoku-grid');
        
        grille.forEach((ligne, i) => {
            ligne.forEach((val, j) => {
                const input = document.createElement('input');
                input.type = 'number';
                input.min = 1;
                input.max = 9;
                input.step = 1;
                input.classList.add('sudoku-case');
                input.addEventListener("keydown", (e) => {
                    const allowed = ["Backspace", "Delete", "Tab", "ArrowLeft", "ArrowRight"];
                    if (allowed.includes(e.key)) return;
                    if (!/^[1-9]$/.test(e.key)) {
                        e.preventDefault();
                    }
                });
                if (val !== 0) {
                    input.value = val;
                    input.disabled = true;
                } else {
                    input.oninput = (e) => {
                        let value = e.target.value.replace(/[^1-9]/g, '');
                        value = value.charAt(0);
                        e.target.value = value;
                        if (value === "") {
                            e.target.classList.remove('success', 'error');
                            return;
                        }
                        let num = Number(value);
                        if (num < 1 || num > 9) {
                            e.target.value = "";
                            return;
                        }
                        if (testCoup(i, j, num)) {
                            e.target.classList.add('success');
                            e.target.classList.remove('error');
                            e.target.disabled = true;
                        } else {
                            e.target.classList.add('error');
                            setTimeout(() => {
                                e.target.value = "";
                                e.target.classList.remove('error');
                            }, 800);
                        }
                    };
                }
                container.appendChild(input);
            });
        });
    </script>
{% endblock %}