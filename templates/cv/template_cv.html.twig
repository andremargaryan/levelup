<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        @page {
            margin: 0;
            size: A4 portrait;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: Arial, Helvetica, sans-serif;
            width: 210mm;
            font-size: 12px;
        }
        table.layout {
            width: 100%;
            border-collapse: collapse;
            min-height: 297mm;
        }
        td.sidebar {
            width: 210px;
            min-height: 297mm;
            background: #1B2A3B;
            color: #fff;
            padding: 40px 22px;
            vertical-align: top;
        }
        td.main {
            min-height: 297mm;
            padding: 40px 30px;
            vertical-align: top;
        }

        .name { font-size: 24px; font-weight: bold; color: #C9A84C; margin-bottom: 6px; }
        .poste { font-size: 13px; color: #E8D49A; margin-bottom: 35px; line-height: 1.6; }

        .sidebar-section { margin-bottom: 30px; }
        .sidebar-section h3 {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #C9A84C;
            border-bottom: 1px solid #C9A84C;
            padding-bottom: 6px;
            margin-bottom: 12px;
        }
        .sidebar-section p { font-size: 11px; color: #ccc; margin-bottom: 8px; line-height: 1.6; }

        .competence-item {
            background: #C9A84C;
            color: #1B2A3B;
            font-size: 10px;
            font-weight: bold;
            padding: 3px 10px;
            border-radius: 10px;
            display: inline-block;
            margin: 3px 3px 3px 0;
        }

        .langue-row { margin-bottom: 8px; }
        .langue-nom { font-size: 12px; display: inline-block; width: 60%; }
        .langue-niveau { font-size: 12px; color: #C9A84C; font-weight: bold; display: inline-block; }

        .section { margin-bottom: 35px; }
        .section h2 {
            font-size: 16px;
            color: #1B2A3B;
            border-left: 4px solid #C9A84C;
            padding-left: 10px;
            margin-bottom: 16px;
            letter-spacing: 0.5px;
        }

        .item { margin-bottom: 16px; }
        .item-header { width: 100%; margin-bottom: 4px; }
        .item-title { font-weight: bold; font-size: 13px; color: #1B2A3B; display: inline-block; width: 65%; }
        .item-date { font-size: 11px; color: #888; display: inline-block; text-align: right; width: 34%; }
        .item-subtitle { font-size: 12px; color: #C9A84C; margin-bottom: 8px; }
        .item-desc { font-size: 11px; color: #555; line-height: 1.7; }
    </style>
</head>
<body>

<table class="layout">
    <tr>
        <td class="sidebar">
            <div class="name">{{ data.prenom }} {{ data.nom }}</div>
            <div class="poste">{{ data.poste }}</div>

            <div class="sidebar-section">
                <h3>Contact</h3>
                {% if data.email %}<p><b><u>Email:</u></b> {{ data.email }}</p>{% endif %}
                {% if data.telephone %}<p><b><u>Téléphone:</u></b> {{ data.telephone }}</p>{% endif %}
                {% if data.ville %}<p><b><u>Localisation:</u></b> {{ data.ville }}</p>{% endif %}
            </div>

            {% if data.competences %}
            <div class="sidebar-section">
                <h3>Compétences</h3>
                {% for comp in data.competences|split(',') %}
                    <span class="competence-item">{{ comp|trim }}</span>
                {% endfor %}
            </div>
            {% endif %}

            {% if data.langue1 %}
            <div class="sidebar-section">
                <h3>Langues</h3>
                <div class="langue-row">
                    <span class="langue-nom">{{ data.langue1 }}</span>
                    <span class="langue-niveau">{{ data.niveau1 }}</span>
                </div>
                {% if data.langue2 %}
                <div class="langue-row">
                    <span class="langue-nom">{{ data.langue2 }}</span>
                    <span class="langue-niveau">{{ data.niveau2 }}</span>
                </div>
                {% endif %}
            </div>
            {% endif %}

            {% if data.loisirs %}
            <div class="sidebar-section">
                <h3>Centres d'intérêt</h3>
                <p>{{ data.loisirs }}</p>
            </div>
            {% endif %}
        </td>

        <td class="main">
            {% if data.diplome %}
            <div class="section">
                <h2>Formation</h2>
                <div class="item">
                    <div class="item-header">
                        <span class="item-title">{{ data.diplome }}</span>
                        <span class="item-date">{{ data.formation_debut }} – {{ data.formation_fin }}</span>
                    </div>
                    <div class="item-subtitle">{{ data.ecole }}</div>
                </div>
            </div>
            {% endif %}

            {% if data.exp_poste %}
            <div class="section">
                <h2>Expérience professionnelle</h2>
                <div class="item">
                    <div class="item-header">
                        <span class="item-title">{{ data.exp_poste }}</span>
                        <span class="item-date">{{ data.exp_debut }} - {{ data.exp_fin }}</span>
                    </div>
                    <div class="item-subtitle">{{ data.exp_entreprise }}</div>
                    <div class="item-desc">{{ data.exp_description }}</div>
                </div>
            </div>
            {% endif %}
        </td>
    </tr>
</table>

</body>
</html>