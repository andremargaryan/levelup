<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Arial, Helvetica, sans-serif; }

        table.layout { width: 100%; border-collapse: collapse; }
        td.sidebar {
            width: 200px;
            background: #1B2A3B;
            color: #fff;
            padding: 30px 20px;
            vertical-align: top;
        }
        td.main {
            padding: 30px 25px;
            vertical-align: top;
        }

        .name { font-size: 18px; font-weight: bold; color: #C9A84C; margin-bottom: 4px; }
        .titre-poste { font-size: 10px; color: #E8D49A; margin-bottom: 20px; }
        .sidebar-section { margin-bottom: 18px; }
        .sidebar-section h3 {
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #C9A84C;
            border-bottom: 1px solid #C9A84C;
            padding-bottom: 4px;
            margin-bottom: 8px;
        }
        .sidebar-section p { font-size: 9px; color: #ccc; margin-bottom: 4px; }
        .competence-item {
            background: #C9A84C;
            color: #1B2A3B;
            font-size: 8px;
            font-weight: bold;
            padding: 2px 8px;
            border-radius: 10px;
            display: inline-block;
            margin: 2px 2px 2px 0;
        }

        .section { margin-bottom: 22px; }
        .section h2 {
            font-size: 13px;
            color: #1B2A3B;
            border-left: 4px solid #C9A84C;
            padding-left: 8px;
            margin-bottom: 10px;
        }
        .item { margin-bottom: 10px; }
        .item-header { display: flex; justify-content: space-between; }
        .item-title { font-weight: bold; font-size: 11px; color: #1B2A3B; }
        .item-date { font-size: 9px; color: #888; }
        .item-subtitle { font-size: 10px; color: #C9A84C; margin-bottom: 3px; }
        .item-desc { font-size: 10px; color: #555; line-height: 1.5; }
        .langue-row { display: flex; justify-content: space-between; margin-bottom: 4px; }
        .langue-nom { font-size: 10px; }
        .langue-niveau { font-size: 10px; color: #C9A84C; font-weight: bold; }
    </style>
</head>
<body>

<table class="layout">
    <tr>
        <td class="sidebar">
            <div class="name">{{ data.prenom }} {{ data.nom }}</div>
            <div class="poste">{{ data.poste }}</div>

            <div class="sidebar-section">
                <h3>Contact</h3>
                {% if data.email %}<p>Email: {{ data.email }}</p>{% endif %}
                {% if data.telephone %}<p>Téléphone: {{ data.telephone }}</p>{% endif %}
                {% if data.ville %}<p>Localisation: {{ data.ville }}</p>{% endif %}
            </div>

            {% if data.competences %}
            <div class="sidebar-section">
                <h3>Compétences</h3>
                {% for comp in data.competences|split(',') %}
                    <span class="competence-item">{{ comp|trim }}</span>
                {% endfor %}
            </div>
            {% endif %}

            {% if data.langue1 %}
            <div class="sidebar-section">
                <h3>Langues</h3>
                <div class="langue-row">
                    <span class="langue-nom">{{ data.langue1 }}</span>
                    <span class="langue-niveau">{{ data.niveau1 }}</span>
                </div>
                {% if data.langue2 %}
                <div class="langue-row">
                    <span class="langue-nom">{{ data.langue2 }}</span>
                    <span class="langue-niveau">{{ data.niveau2 }}</span>
                </div>
                {% endif %}
            </div>
            {% endif %}

            {% if data.loisirs %}
            <div class="sidebar-section">
                <h3>Centres d'intérêt</h3>
                <p>{{ data.loisirs }}</p>
            </div>
            {% endif %}
        </td>

        <td class="main">
            {% if data.diplome %}
            <div class="section">
                <h2>Formation</h2>
                <div class="item">
                    <div class="item-header">
                        <span class="item-title">{{ data.diplome }}</span>
                        <span class="item-date">{{ data.formation_debut }} – {{ data.formation_fin }}</span>
                    </div>
                    <div class="item-subtitle">{{ data.ecole }}</div>
                </div>
            </div>
            {% endif %}

            {% if data.exp_poste %}
            <div class="section">
                <h2>Expérience professionnelle</h2>
                <div class="item">
                    <div class="item-header">
                        <span class="item-title">{{ data.exp_poste }}</span>
                        <span class="item-date">{{ data.exp_debut }} - {{ data.exp_fin }}</span>
                    </div>
                    <div class="item-subtitle">{{ data.exp_entreprise }}</div>
                    <div class="item-desc">{{ data.exp_description }}</div>
                </div>
            </div>
            {% endif %}
        </td>
    </tr>
</table>

</body>
</html>