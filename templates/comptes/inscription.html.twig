{% extends 'home/base1.html.twig' %}

{% block title %}Inscrivez-vous
{% endblock %}

{% block body %}
	<div class="container-connexion">
		<h1 class="mb-4">Inscrivez-vous</h1>
		{{ form_start(form) }}
		<div class="elements">
			{{ form_row(form.nom) }}
		</div>
		<div class="elements">
			{{ form_row(form.prenom) }}
		</div>
		<div class="elements">
			{{ form_row(form.mot_de_passe) }}
		</div>
		<div class="elements">
			{{ form_row(form.mail) }}
		</div>
		<div class="elements">
			{{ form_row(form.save) }}
		</div>
		{{ form_end(form) }}

		<a href="{{ path('app_employeur_dashboard') }}" class="btn-employeur">
        Accéder à l'espace Employeur
    </a>
	</div>

	<style>
    body { background: #F5F0E8; }

    .container-connexion {
        max-width: 460px;
        margin: 4rem auto;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 8px 40px rgba(27,42,59,.12);
        padding: 2.5rem;
    }

    .container-connexion h1 {
        color: #1B2A3B;
        font-weight: 800;
        font-size: 1.8rem;
        text-align: center;
        margin-bottom: 1.5rem;
    }

    .container-connexion label {
        display: block;
        font-weight: 600;
        font-size: .85rem;
        color: #1B2A3B;
        margin-bottom: .4rem;
    }

    .container-connexion input {
        width: 100%;
        padding: .75rem 1rem;
        border: 1.5px solid #E0DDD6;
        border-radius: 10px;
        font-size: .95rem;
        color: #1B2A3B;
        background: #FAFAF8;
        transition: border-color .2s, box-shadow .2s;
        outline: none;
        box-sizing: border-box;
    }
    .container-connexion input:focus {
        border-color: #C9A84C;
        box-shadow: 0 0 0 3px rgba(201,168,76,.15);
    }

    .elements { margin-bottom: 1.1rem; }

    .container-connexion .btn {
        display: block;
        width: 100%;
        text-align: center;
        background: #C9A84C;
        color: #1B2A3B !important;
        font-weight: 700;
        font-size: 1rem;
        border: none;
        border-radius: 50px;
        padding: .8rem 1.5rem;
        cursor: pointer;
        transition: background .2s, transform .15s;
        text-decoration: none;
        box-sizing: border-box;
    }
    .container-connexion .btn:hover {
        background: #E8D49A;
        transform: translateY(-2px);
    }

    .separateur {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 1.25rem 0;
        color: #aaa;
        font-size: .85rem;
    }
    .separateur::before,
    .separateur::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #E0DDD6;
    }

    .btn-employeur {
        display: block;
        width: 90%;
        text-align: center;
        background: #1B2A3B;
        color: #C9A84C !important;
        font-weight: 600;
        border-radius: 50px;
        padding: .8rem 1.5rem;
        text-decoration: none;
        transition: background .2s, transform .15s;
    }
    .btn-employeur:hover {
        background: #C9A84C;
        color: #1B2A3B !important;
        transform: translateY(-2px);
    }
</style>
{% endblock %}
