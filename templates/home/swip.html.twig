{% extends 'home/base1.html.twig' %}
{% block body %}
{% if offre %}
  <div class="container-card">
    <div class="card" style="width: 18rem;" data-id="{{ offre.id }}">
      <div class="card-body">
          <span class="badge">{{ offre.tag }}</span>
          <h1 class="card-title">{{ offre.titre }}</h1>
          <p class="card-text">{{ offre.description }}</p>
          <p><strong>{{ offre.entreprise }}</strong></p>
          <button type="button" class="btn btn-danger btn-lg" id="dislike"><i class="fa-solid fa-x" style="color: rgba(12, 28, 44, 1.00);"></i></button>
          <button type="button" class="btn btn-success btn-lg" id="like"><i class="fa-solid fa-heart" style="color: rgba(12, 28, 44, 1.00);"></i></button>
      </div>
    </div>
  </div>
{% else %}
<div class="container-card">
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; gap: 15px; color: #0c1c2c;">
        <span style="font-size: 3rem;">📭</span>
        <h2 style="font-family: 'Playfair Display', serif; font-size: 1.5rem;">Vous arrivez trop tôt !</h2>
        <p style="color: #888; font-size: 1rem;">Aucune offre de stage disponible pour le moment.</p>
        <a href="{{ path('app_home_page') }}" class="btn">Retour à l'accueil</a>
    </div>
</div>
{% endif %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
async function swipeCard(dir) {
  const card = document.querySelector('.card');
  if (!card) return;

  const currentId = card.dataset.id;

  card.style.transition = 'transform 0.5s cubic-bezier(.4,0,.2,1), opacity 0.4s';
  card.style.transform = dir === 'right'
    ? 'translateX(130%) rotate(20deg)'
    : 'translateX(-130%) rotate(-20deg)';
  card.style.opacity = '0';


  const response = await fetch(`/offres/next/${currentId}`);
  const data = await response.json();

  setTimeout(() => {
    if (data.done) {
      card.innerHTML = '<p>Plus aucune offre disponible !</p>';
      card.style.transform = '';
      card.style.opacity = '1';
      return;
    }

    card.dataset.id          = data.id;
    card.querySelector('.card-title').textContent = data.titre;
    card.querySelector('.card-text').textContent  = data.description;

    card.style.transition = 'none';
    card.style.transform  = dir === 'right'
      ? 'translateX(-130%) rotate(-20deg)'
      : 'translateX(130%) rotate(20deg)';
    card.style.opacity = '0';

    requestAnimationFrame(() => {
      card.style.transition = 'transform 0.5s cubic-bezier(.4,0,.2,1), opacity 0.4s';
      card.style.transform  = '';
      card.style.opacity    = '1';
    });
  }, 500);
}

document.getElementById('like').addEventListener('click', () => swipeCard('right'));
document.getElementById('dislike').addEventListener('click', () => swipeCard('left'));
</script>
{% endblock %}