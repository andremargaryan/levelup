{% extends 'home/base1.html.twig' %}

{% block title %}Espace Employeur – LevelUp{% endblock %}

{% block body %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/dashboard.css') }}">
{% endblock %}
<header class="emp-header">
    <h1>Espace <span>Employeur</span></h1>
    <a href="{{ path('app_employeur_nouvelle_offre') }}" class="btn-gold">+ Publier une offre</a>
</header>

<nav class="emp-tabs">
    <button class="emp-tab active" onclick="showTab('offres', this)">📋 Mes offres</button>
    <button class="emp-tab" onclick="showTab('candidatures', this)">👥 Candidatures</button>
    <button class="emp-tab" onclick="showTab('profils', this)">🔍 Swiper des profils</button>
</nav>

<main class="emp-content">

    <div class="tab-panel active" id="tab-offres">
        <div class="section-top">
            <h2>Mes offres de stage</h2>
            <span class="badge">{{ offres|length }}</span>
        </div>
        <div class="offres-grid">
            {% for offre in offres %}
                <a href="{{ path('app_employeur_offre_detail', {id: offre.id}) }}" 
                style="text-decoration: none; color: inherit;">
                    <div class="offre-card">
                        <h3>{{ offre.titre }}</h3>
                        <div class="offre-tags">
                            <span class="tag">🏢 {{ offre.entreprise }}</span>
                            <span class="tag">🏷️ {{ offre.tag }}</span>
                        </div>
                        <div class="offre-footer">
                            <span class="nb-cand">{{ offre.description }}</span>
                        </div>
                    </div>
                </a>
            {% else %}
                <p>Aucune offre trouvée.</p>
            {% endfor %}
        </div>
    </div>

    <div class="tab-panel" id="tab-candidatures">
        <div class="section-top">
            <h2>Candidatures reçues</h2>
            <span class="badge">{{ candidatures|length }}</span>
        </div>
        <div class="candidatures-list">
            {% for cand in candidatures %}
            {% set statutClass = cand.statut == 'Acceptée' ? 'acceptee' : (cand.statut == 'Refusée' ? 'refusee' : 'en-attente') %}
            <div class="cand-item">
                <div class="avatar">{{ cand.avatar }}</div>
                <div class="cand-info">
                    <div class="cand-nom">{{ cand.nom }}</div>
                    <div class="cand-poste">{{ cand.poste }}</div>
                </div>
                <div class="cand-right">
                    <span class="statut {{ statutClass }}">{{ cand.statut }}</span>
                    <span class="cand-date">{{ cand.date|date('d/m/Y') }}</span>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    <div class="tab-panel" id="tab-profils">
        <div class="section-top">
            <h2>Profils d'étudiants</h2>
            <span class="badge">{{ profils|length }}</span>
        </div>
        <div class="profils-grid">
            {% for profil in profils %}
            <div class="profil-card">
                <div class="profil-avatar">{{ profil.avatar }}</div>
                <div class="profil-nom">{{ profil.nom }}</div>
                <div class="profil-formation">{{ profil.formation }}</div>
                <div class="profil-competences">
                    {% for comp in profil.competences %}
                        <span class="tag">{{ comp }}</span>
                    {% endfor %}
                </div>
                <div class="profil-dispo">📅 Disponible : {{ profil.disponible }}</div>
                <div class="profil-actions">
                    <button class="btn-refuse">✕</button>
                    <button class="btn-accept">✓</button>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

</main>

<script>
function showTab(name, btn) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.emp-tab').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + name).classList.add('active');
    btn.classList.add('active');
}
</script>
{% endblock %}