{% extends 'home/base1.html.twig' %}

{% block title %}Espace Employeur – LevelUp{% endblock %}

{% block body %}
<style>
    :root {
        --gold:       #C9A84C;
        --gold-light: #E8D49A;
        --navy:       #1B2A3B;
        --cream:      #F5F0E8;
        --muted:      #6B7A8D;
        --radius:     12px;
        --shadow:     0 4px 24px rgba(27,42,59,.10);
    }

    * { box-sizing: border-box; }

    .emp-header {
        background: var(--navy);
        color: #fff;
        padding: 1.25rem 2.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .emp-header h1 { font-size: 1.4rem; font-weight: 800; }
    .emp-header h1 span { color: var(--gold); }

    .btn-gold {
        background: var(--gold);
        color: var(--navy);
        font-weight: 700;
        border: none;
        border-radius: 50px;
        padding: .6rem 1.4rem;
        text-decoration: none;
        font-size: .95rem;
        transition: background .2s, transform .15s;
        display: inline-block;
    }
    .btn-gold:hover { background: var(--gold-light); transform: translateY(-2px); }

    .emp-tabs {
        display: flex;
        background: #fff;
        border-bottom: 2px solid #EDE8DE;
        padding: 0 2.5rem;
    }
    .emp-tab {
        padding: 1rem 1.5rem;
        font-weight: 700;
        font-size: .95rem;
        color: var(--muted);
        cursor: pointer;
        border-bottom: 3px solid transparent;
        margin-bottom: -2px;
        transition: color .2s, border-color .2s;
        background: none;
        border-top: none;
        border-left: none;
        border-right: none;
    }
    .emp-tab:hover { color: var(--navy); }
    .emp-tab.active { color: var(--navy); border-bottom-color: var(--gold); }

    .emp-content {
        max-width: 1100px;
        margin: 2rem auto;
        padding: 0 1.5rem;
    }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    .offres-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.25rem;
        margin-top: 1rem;
    }
    .offre-card {
        background: #fff;
        border: 1.5px solid #EDE8DE;
        border-radius: var(--radius);
        padding: 1.25rem;
        box-shadow: var(--shadow);
        transition: border-color .2s, transform .2s;
    }
    .offre-card:hover { border-color: var(--gold); transform: translateY(-3px); }
    .offre-card h3 { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: .5rem; }
    .offre-tags { display: flex; gap: .5rem; flex-wrap: wrap; margin-bottom: .75rem; }
    .tag {
        font-size: .75rem;
        background: var(--cream);
        color: var(--muted);
        border-radius: 50px;
        padding: .15rem .65rem;
    }
    .offre-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: .75rem;
        padding-top: .75rem;
        border-top: 1px solid #EDE8DE;
    }
    .offre-footer .nb-cand { color: var(--gold); font-weight: 700; font-size: .85rem; }
    .offre-footer .date { color: var(--muted); font-size: .78rem; }

    .candidatures-list { display: flex; flex-direction: column; gap: .85rem; margin-top: 1rem; }
    .cand-item {
        background: #fff;
        border: 1.5px solid #EDE8DE;
        border-radius: var(--radius);
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: var(--shadow);
        transition: border-color .2s;
    }
    .cand-item:hover { border-color: var(--gold); }
    .avatar {
        width: 46px; height: 46px;
        border-radius: 50%;
        background: var(--navy);
        color: var(--gold);
        font-weight: 800;
        font-size: .85rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .cand-info { flex: 1; }
    .cand-info .cand-nom { font-weight: 700; color: var(--navy); }
    .cand-info .cand-poste { font-size: .82rem; color: var(--muted); margin-top: .15rem; }
    .cand-right { display: flex; flex-direction: column; align-items: flex-end; gap: .3rem; }
    .statut {
        font-size: .75rem; font-weight: 700;
        border-radius: 50px; padding: .2rem .75rem;
    }
    .statut.en-attente { background: #FFF4E0; color: #B07A00; }
    .statut.acceptee   { background: #E6F7EE; color: #2E7D55; }
    .statut.refusee    { background: #FDEAEA; color: #B03030; }
    .cand-date { font-size: .75rem; color: var(--muted); }

    .profils-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1.25rem;
        margin-top: 1rem;
    }
    .profil-card {
        background: #fff;
        border: 1.5px solid #EDE8DE;
        border-radius: var(--radius);
        padding: 1.5rem;
        text-align: center;
        box-shadow: var(--shadow);
        transition: transform .2s, border-color .2s;
    }
    .profil-card:hover { transform: translateY(-4px); border-color: var(--gold); }
    .profil-avatar {
        width: 64px; height: 64px;
        border-radius: 50%;
        background: var(--navy);
        color: var(--gold);
        font-weight: 800;
        font-size: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto .75rem;
    }
    .profil-nom { font-weight: 700; font-size: 1rem; color: var(--navy); }
    .profil-formation { font-size: .82rem; color: var(--muted); margin-top: .2rem; margin-bottom: .75rem; }
    .profil-competences { display: flex; gap: .4rem; flex-wrap: wrap; justify-content: center; margin-bottom: .75rem; }
    .profil-competences .tag { background: #EEF2FF; color: #3B5BDB; }
    .profil-dispo { font-size: .78rem; color: var(--muted); margin-bottom: 1rem; }
    .profil-actions { display: flex; gap: .5rem; justify-content: center; }
    .btn-refuse {
        width: 44px; height: 44px;
        border-radius: 50%;
        border: 2px solid #E05252;
        background: #fff;
        color: #E05252;
        font-size: 1.2rem;
        cursor: pointer;
        transition: background .2s;
    }
    .btn-refuse:hover { background: #FDEAEA; }
    .btn-accept {
        width: 44px; height: 44px;
        border-radius: 50%;
        border: 2px solid #4CAF82;
        background: #fff;
        color: #4CAF82;
        font-size: 1.2rem;
        cursor: pointer;
        transition: background .2s;
    }
    .btn-accept:hover { background: #E6F7EE; }

    .section-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: .5rem;
    }
    .section-top h2 { font-size: 1.1rem; font-weight: 700; color: var(--navy); }
    .badge {
        background: var(--gold);
        color: var(--navy);
        font-weight: 700;
        font-size: .78rem;
        border-radius: 50px;
        padding: .2rem .7rem;
    }
</style>

<header class="emp-header">
    <h1>Espace <span>Employeur</span></h1>
    <a href="{{ path('app_employeur_nouvelle_offre') }}" class="btn-gold">+ Publier une offre</a>
</header>

<nav class="emp-tabs">
    <button class="emp-tab active" onclick="showTab('offres', this)"> Mes offres</button>
    <button class="emp-tab" onclick="showTab('candidatures', this)"> Candidatures</button>
    <button class="emp-tab" onclick="showTab('profils', this)">Swiper des profils</button>
</nav>

<main class="emp-content">

    <div class="tab-panel active" id="tab-offres">
        <div class="section-top">
            <h2>Mes offres de stage</h2>
            <span class="badge">{{ offres|length }}</span>
        </div>
        <div class="offres-grid">
            {% for offre in offres %}
            <div class="offre-card">
                <h3>{{ offre.titre }}</h3>
                <div class="offre-tags">
                    <span class="tag">{{ offre.localisation }}</span>
                    <span class="tag">{{ offre.type }}</span>
                </div>
                <div class="offre-footer">
                    <span class="nb-cand">{{ offre.candidatures }} candidature{{ offre.candidatures > 1 ? 's' : '' }}</span>
                    <span class="date">{{ offre.date|date('d/m/Y') }}</span>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    <div class="tab-panel" id="tab-candidatures">
        <div class="section-top">
            <h2>Candidatures reçues</h2>
            <span class="badge">{{ candidatures|length }}</span>
        </div>
        <div class="candidatures-list">
            {% for cand in candidatures %}
            {% set statutClass = cand.statut == 'Acceptée' ? 'acceptee' : (cand.statut == 'Refusée' ? 'refusee' : 'en-attente') %}
            <div class="cand-item">
                <div class="avatar">{{ cand.avatar }}</div>
                <div class="cand-info">
                    <div class="cand-nom">{{ cand.nom }}</div>
                    <div class="cand-poste">{{ cand.poste }}</div>
                </div>
                <div class="cand-right">
                    <span class="statut {{ statutClass }}">{{ cand.statut }}</span>
                    <span class="cand-date">{{ cand.date|date('d/m/Y') }}</span>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    <div class="tab-panel" id="tab-profils">
        <div class="section-top">
            <h2>Profils d'étudiants</h2>
            <span class="badge">{{ profils|length }}</span>
        </div>
        <div class="profils-grid">
            {% for profil in profils %}
            <div class="profil-card">
                <div class="profil-avatar">{{ profil.avatar }}</div>
                <div class="profil-nom">{{ profil.nom }}</div>
                <div class="profil-formation">{{ profil.formation }}</div>
                <div class="profil-competences">
                    {% for comp in profil.competences %}
                        <span class="tag">{{ comp }}</span>
                    {% endfor %}
                </div>
                <div class="profil-dispo"> Disponible : {{ profil.disponible }}</div>
                <div class="profil-actions">
                    <button class="btn-refuse">✕</button>
                    <button class="btn-accept">✓</button>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

</main>

<script>
function showTab(name, btn) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.emp-tab').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + name).classList.add('active');
    btn.classList.add('active');
}
</script>
{% endblock %}